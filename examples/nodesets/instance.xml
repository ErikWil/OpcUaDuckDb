<?xml version="1.0" encoding="utf-8"?>
<!--
  Example Nodeset2 instance file for a simple process plant.

  Creates instances of the types defined in type_library.xml:
    - Pump01          (PumpType)           – Feed pump
    - Pump02          (PumpType)           – Transfer pump
    - FlowMeter01     (FlowMeterType)      – Inlet flow meter
    - TempSensor01    (TemperatureSensorType) – Reactor temperature
    - TempSensor02    (TemperatureSensorType) – Outlet temperature
    - ControlValve01  (ValveType)          – Inlet control valve

  Namespace index 1 = urn:example:process-equipment-types (types)
  Namespace index 2 = urn:example:process-plant-instance  (instances)
-->
<UANodeSet xmlns="http://opcfoundation.org/UA/2011/03/UANodeSet.xsd"
           xmlns:uax="http://opcfoundation.org/UA/2008/02/Types.xsd"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://opcfoundation.org/UA/2011/03/UANodeSet.xsd">

  <NamespaceUris>
    <Uri>urn:example:process-equipment-types</Uri>
    <Uri>urn:example:process-plant-instance</Uri>
  </NamespaceUris>

  <Aliases>
    <Alias Alias="Boolean">i=1</Alias>
    <Alias Alias="Double">i=11</Alias>
    <Alias Alias="String">i=12</Alias>
    <Alias Alias="HasComponent">i=47</Alias>
    <Alias Alias="HasProperty">i=46</Alias>
    <Alias Alias="HasTypeDefinition">i=40</Alias>
    <Alias Alias="Organizes">i=35</Alias>
  </Aliases>

  <!-- ================================================================== -->
  <!-- Plant folder under Objects (i=85)                                   -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;i=100" BrowseName="2:ProcessPlant">
    <DisplayName>ProcessPlant</DisplayName>
    <Description>Root folder for the example process plant</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">i=85</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=61</Reference>
    </References>
  </UAObject>

  <!-- ================================================================== -->
  <!-- Pump01 – Feed pump                                                  -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;s=Pump01" BrowseName="2:Pump01">
    <DisplayName>Pump01</DisplayName>
    <Description>Feed pump</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">ns=2;i=100</Reference>
      <Reference ReferenceType="HasTypeDefinition">ns=1;i=2000</Reference>
    </References>
  </UAObject>

  <UAVariable NodeId="ns=2;s=Pump01.Tag" BrowseName="1:Tag" DataType="String" AccessLevel="3">
    <DisplayName>Tag</DisplayName>
    <Value><uax:String>P-101</uax:String></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=Pump01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=Pump01.Speed" BrowseName="1:Speed" DataType="Double" AccessLevel="3">
    <DisplayName>Speed</DisplayName>
    <Value><uax:Double>1200</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=Pump01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=Pump01.IsRunning" BrowseName="1:IsRunning" DataType="Boolean" AccessLevel="3">
    <DisplayName>IsRunning</DisplayName>
    <Value><uax:Boolean>true</uax:Boolean></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=Pump01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=Pump01.Power" BrowseName="1:Power" DataType="Double" AccessLevel="1">
    <DisplayName>Power</DisplayName>
    <Value><uax:Double>15.5</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=Pump01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <!-- ================================================================== -->
  <!-- Pump02 – Transfer pump                                              -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;s=Pump02" BrowseName="2:Pump02">
    <DisplayName>Pump02</DisplayName>
    <Description>Transfer pump</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">ns=2;i=100</Reference>
      <Reference ReferenceType="HasTypeDefinition">ns=1;i=2000</Reference>
    </References>
  </UAObject>

  <UAVariable NodeId="ns=2;s=Pump02.Tag" BrowseName="1:Tag" DataType="String" AccessLevel="3">
    <DisplayName>Tag</DisplayName>
    <Value><uax:String>P-102</uax:String></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=Pump02</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=Pump02.Speed" BrowseName="1:Speed" DataType="Double" AccessLevel="3">
    <DisplayName>Speed</DisplayName>
    <Value><uax:Double>800</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=Pump02</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=Pump02.IsRunning" BrowseName="1:IsRunning" DataType="Boolean" AccessLevel="3">
    <DisplayName>IsRunning</DisplayName>
    <Value><uax:Boolean>false</uax:Boolean></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=Pump02</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=Pump02.Power" BrowseName="1:Power" DataType="Double" AccessLevel="1">
    <DisplayName>Power</DisplayName>
    <Value><uax:Double>0</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=Pump02</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <!-- ================================================================== -->
  <!-- FlowMeter01 – Inlet flow meter                                      -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;s=FlowMeter01" BrowseName="2:FlowMeter01">
    <DisplayName>FlowMeter01</DisplayName>
    <Description>Inlet flow meter</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">ns=2;i=100</Reference>
      <Reference ReferenceType="HasTypeDefinition">ns=1;i=3000</Reference>
    </References>
  </UAObject>

  <UAVariable NodeId="ns=2;s=FlowMeter01.Tag" BrowseName="1:Tag" DataType="String" AccessLevel="3">
    <DisplayName>Tag</DisplayName>
    <Value><uax:String>FT-201</uax:String></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=FlowMeter01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=FlowMeter01.FlowRate" BrowseName="1:FlowRate" DataType="Double" AccessLevel="1">
    <DisplayName>FlowRate</DisplayName>
    <Value><uax:Double>42.7</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=FlowMeter01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=FlowMeter01.TotalVolume" BrowseName="1:TotalVolume" DataType="Double" AccessLevel="1">
    <DisplayName>TotalVolume</DisplayName>
    <Value><uax:Double>128456.3</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=FlowMeter01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <!-- ================================================================== -->
  <!-- TempSensor01 – Reactor temperature                                  -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;s=TempSensor01" BrowseName="2:TempSensor01">
    <DisplayName>TempSensor01</DisplayName>
    <Description>Reactor temperature sensor</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">ns=2;i=100</Reference>
      <Reference ReferenceType="HasTypeDefinition">ns=1;i=4000</Reference>
    </References>
  </UAObject>

  <UAVariable NodeId="ns=2;s=TempSensor01.Tag" BrowseName="1:Tag" DataType="String" AccessLevel="3">
    <DisplayName>Tag</DisplayName>
    <Value><uax:String>TT-301</uax:String></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=TempSensor01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=TempSensor01.Temperature" BrowseName="1:Temperature" DataType="Double" AccessLevel="1">
    <DisplayName>Temperature</DisplayName>
    <Value><uax:Double>85.2</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=TempSensor01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=TempSensor01.HighAlarm" BrowseName="1:HighAlarm" DataType="Double" AccessLevel="3">
    <DisplayName>HighAlarm</DisplayName>
    <Value><uax:Double>100.0</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=TempSensor01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=TempSensor01.LowAlarm" BrowseName="1:LowAlarm" DataType="Double" AccessLevel="3">
    <DisplayName>LowAlarm</DisplayName>
    <Value><uax:Double>20.0</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=TempSensor01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <!-- ================================================================== -->
  <!-- TempSensor02 – Outlet temperature                                   -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;s=TempSensor02" BrowseName="2:TempSensor02">
    <DisplayName>TempSensor02</DisplayName>
    <Description>Outlet temperature sensor</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">ns=2;i=100</Reference>
      <Reference ReferenceType="HasTypeDefinition">ns=1;i=4000</Reference>
    </References>
  </UAObject>

  <UAVariable NodeId="ns=2;s=TempSensor02.Tag" BrowseName="1:Tag" DataType="String" AccessLevel="3">
    <DisplayName>Tag</DisplayName>
    <Value><uax:String>TT-302</uax:String></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=TempSensor02</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=TempSensor02.Temperature" BrowseName="1:Temperature" DataType="Double" AccessLevel="1">
    <DisplayName>Temperature</DisplayName>
    <Value><uax:Double>45.8</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=TempSensor02</Reference>
