    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=TempSensor02.HighAlarm" BrowseName="1:HighAlarm" DataType="Double" AccessLevel="3">
    <DisplayName>HighAlarm</DisplayName>
    <Value><uax:Double>60.0</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=TempSensor02</Reference>
