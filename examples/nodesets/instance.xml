    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=TempSensor02.LowAlarm" BrowseName="1:LowAlarm" DataType="Double" AccessLevel="3">
    <DisplayName>LowAlarm</DisplayName>
    <Value><uax:Double>10.0</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=TempSensor02</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <!-- ================================================================== -->
  <!-- ControlValve01 – Inlet control valve                                -->
  <!-- ================================================================== -->
  <UAObject NodeId="ns=2;s=ControlValve01" BrowseName="2:ControlValve01">
    <DisplayName>ControlValve01</DisplayName>
    <Description>Inlet control valve</Description>
    <References>
      <Reference ReferenceType="Organizes" IsForward="false">ns=2;i=100</Reference>
      <Reference ReferenceType="HasTypeDefinition">ns=1;i=5000</Reference>
    </References>
  </UAObject>

  <UAVariable NodeId="ns=2;s=ControlValve01.Tag" BrowseName="1:Tag" DataType="String" AccessLevel="3">
    <DisplayName>Tag</DisplayName>
    <Value><uax:String>CV-401</uax:String></Value>
    <References>
      <Reference ReferenceType="HasProperty" IsForward="false">ns=2;s=ControlValve01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=ControlValve01.Position" BrowseName="1:Position" DataType="Double" AccessLevel="3">
    <DisplayName>Position</DisplayName>
    <Value><uax:Double>65.0</uax:Double></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=ControlValve01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

  <UAVariable NodeId="ns=2;s=ControlValve01.IsOpen" BrowseName="1:IsOpen" DataType="Boolean" AccessLevel="1">
    <DisplayName>IsOpen</DisplayName>
    <Value><uax:Boolean>true</uax:Boolean></Value>
    <References>
      <Reference ReferenceType="HasComponent" IsForward="false">ns=2;s=ControlValve01</Reference>
      <Reference ReferenceType="HasTypeDefinition">i=63</Reference>
    </References>
  </UAVariable>

</UANodeSet>
